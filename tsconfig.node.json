{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    // Inkludera alla API-filer med rätt filändelse
    "api/**/*.ts",

    // Inkludera de lib-filer som servern använder
    "src/lib/clickup.ts",
    "src/lib/supabase-admin.ts",
    "src/lib/pdf-generator.ts",
    "src/types/database.ts"

    // OBS: vite.config.ts kan inte typkollas här — Vite är ESM-only och detta
    // projekt använder NodeNext utan "type": "module" i package.json.
    // Vite validerar själv configen vid build.
  ]
}